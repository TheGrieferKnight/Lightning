{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lightning",
  "version": "0.1.0",
  "identifier": "com.lightning.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main1",
        "title": "Lightning App",
        "width": 800,
        "height": 600,
        "resizable": true,
        "url": "index.html"
      },
      {
        "label": "main2",
        "title": "Lightning Summoner Spell",
        "width": 800,
        "height": 600,
        "resizable": true,
        "url": "index_copy.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
